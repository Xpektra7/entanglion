{
  "name": "entanglion-desktop",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run typecheck",
    "build:web": "bun build src/web/main.ts --outfile dist/web.js --target browser",
    "serve:web": "bun run src/web/server.ts",
    "web": "bun run build:web && bun run serve:web",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "pixi.js": "^8.18.1"
  }
}
